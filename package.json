{
  "name": "sort-zone-solution-desktop",
  "version": "2.1.0",
  "description": "Windows desktop app for Sort Zone labels, OV, PS, STG, ENDCP, Quick Print, silent printing and cluster controls.",
  "main": "src/main.js",
  "author": "Imran Ali Soomro",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis portable --publish never",
    "pack": "electron-builder --win portable --publish never"
  },
  "devDependencies": {
    "electron": "30.5.1",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.imrsooms.sortzonesolution",
    "productName": "Sort Zone Solution",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}